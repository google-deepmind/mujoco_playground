  <default>
    <default class="k1">
      <geom condim="1" contype="0" conaffinity="0" material="medium_gray"/>
      <site rgba="1 0 0 1" size="0.01" group="5"/>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom group="3"/>
        <default class="foot">
          <geom size="0.09 0.035 0.018" pos="0.026 0 -0.02" type="box" contype="4" conaffinity="4"/>
          <default class="foot_sphere">
            <geom contype="2" conaffinity="1" size=".01" type="sphere"/>
          </default>
        </default>
      </default>

      <!-- Gains follow booster_train: kp = armature*(2*pi*f)^2, kd = 2*zeta*armature*(2*pi*f);
           legs f=4Hz (zeta=1.5, knee zeta=1.0), arms/head f=10Hz zeta=2.
           Effort limits from the Booster actuator catalog (E6408/E4315/E4310/E6416/R14/HT4438). -->
      <joint frictionloss="0"/>
      <position inheritrange="1"/>

      <default class="head">
        <joint actuatorfrcrange="-6 6" damping="0.251" armature="0.001"/>
        <position kp="3.948"/>
        <default class="head_yaw">
          <joint axis="0 0 1" range="-1 1"/>
        </default>
        <default class="head_pitch">
          <joint axis="0 1 0" range="-0.349 0.855"/>
        </default>
      </default>
      <default class="shoulder">
        <joint actuatorfrcrange="-14 14" damping="0.251" armature="0.001"/>
        <position kp="3.948"/>
        <default class="shoulder_pitch">
          <joint axis="0 1 0" range="-3.316 1.22"/>
        </default>
        <default class="shoulder_roll">
          <joint axis="1 0 0"/>
        </default>
      </default>
      <default class="elbow">
        <joint actuatorfrcrange="-14 14" damping="0.251" armature="0.001"/>
        <position kp="3.948"/>
        <default class="elbow_pitch">
          <joint axis="0 1 0" range="-2.27 2.27"/>
        </default>
        <default class="elbow_yaw">
          <joint axis="0 0 1"/>
        </default>
      </default>
      <default class="hip">
        <default class="hip_pitch">
          <joint axis="0 1 0" range="-1.8 1.57" actuatorfrcrange="-68 68" damping="3.605" armature="0.0478125"/>
          <position kp="30.201"/>
        </default>
        <default class="hip_roll">
          <joint axis="1 0 0" actuatorfrcrange="-76 76" damping="2.56" armature="0.0339552"/>
          <position kp="21.448"/>
        </default>
        <default class="hip_yaw">
          <joint axis="0 0 1" range="-1 1" actuatorfrcrange="-38.3 38.3" damping="2.13" armature="0.0282528"/>
          <position kp="17.846"/>
        </default>
      </default>
      <default class="knee">
        <joint axis="0 1 0" range="0 2.23" actuatorfrcrange="-112 112" damping="4.807" armature="0.095625"/>
        <position kp="60.402"/>
      </default>
      <default class="ankle">
        <position kp="35.692"/>
        <joint damping="4.26" armature="0.0565056"/>
        <default class="ankle_pitch">
          <joint axis="0 1 0" range="-0.87 0.345" actuatorfrcrange="-38.3 38.3"/>
        </default>
        <default class="ankle_roll">
          <joint axis="1 0 0" range="-0.345 0.345" actuatorfrcrange="-38.3 38.3"/>
        </default>
      </default>
    </default>
  </default>

